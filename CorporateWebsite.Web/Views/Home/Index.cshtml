@* CTA Section *@
<section class="cta-section section-padding" aria-labelledby="cta-title">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8 text-center" data-aos="fade-up">
                <h2 id="cta-title" class="cta-title">@Localizer["Ready to Start Your Project?"]</h2>
                <p class="cta-text">@Localizer["Contact us today for a free consultation"]</p>
                <div class="cta-actions mt-4">
                    <a href="@LocalizationService.GetLocalizedUrl("/contact", Model.CurrentCulture)" class="btn btn-primary btn-lg me-2">
                        <i class="fas fa-envelope me-2"></i>@Localizer["Get in Touch"]
                    </a>
                    <a href="@LocalizationService.GetLocalizedUrl("/services", Model.CurrentCulture)" class="btn btn-outline-primary btn-lg">
                        <i class="fas fa-briefcase me-2"></i>@Localizer["Our Services"]
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>

@* Stats Counter *@
<section class="stats-section section-padding bg-primary text-white" aria-labelledby="stats-title">
    <div class="container">
        <div class="row text-center">
            <div class="col-md-3 col-6 mb-4" data-aos="fade-up">
                <div class="stat-item">
                    <div class="stat-number" data-count="150">0</div>
                    <div class="stat-label">@Localizer["Projects Completed"]</div>
                </div>
            </div>
            <div class="col-md-3 col-6 mb-4" data-aos="fade-up" data-aos-delay="100">
                <div class="stat-item">
                    <div class="stat-number" data-count="50">0</div>
                    <div class="stat-label">@Localizer["Happy Clients"]</div>
                </div>
            </div>
            <div class="col-md-3 col-6 mb-4" data-aos="fade-up" data-aos-delay="200">
                <div class="stat-item">
                    <div class="stat-number" data-count="12">0</div>
                    <div class="stat-label">@Localizer["Years Experience"]</div>
                </div>
            </div>
            <div class="col-md-3 col-6 mb-4" data-aos="fade-up" data-aos-delay="300">
                <div class="stat-item">
                    <div class="stat-number" data-count="25">0</div>
                    <div class="stat-label">@Localizer["Team Members"]</div>
                </div>
            </div>
        </div>
    </div>
</section>