@model CorporateWebsite.Web.ViewComponents.LanguageSwitcher.LanguageSwitcherViewModel
@inject ILocalizationService LocalizationService

@if (Model.Languages.Count > 1)
{
    <div class="language-switcher dropdown">
        <button class="btn btn-link dropdown-toggle d-flex align-items-center gap-1" type="button" data-bs-toggle="dropdown" aria-expanded="false" aria-label="@Localizer["Select Language"]">
            @{
                var currentLang = Model.Languages.FirstOrDefault(l => l.Code == Model.CurrentCulture);
            }
            @if (currentLang != null)
            {
                <span class="flag-icon">@currentLang.FlagIcon</span>
                <span class="lang-code">@currentLang.Code.ToUpper()</span>
            }
            else
            {
                <span class="flag-icon">🇮🇷</span>
                <span class="lang-code">FA</span>
            }
        </button>
        <ul class="dropdown-menu dropdown-menu-end" role="menu">
            @foreach (var lang in Model.Languages)
            {
                var isCurrent = lang.Code == Model.CurrentCulture;
                var url = LocalizationService.GetLocalizedUrl(Context.Request.Path, lang.Code);
                
                <li role="none">
                    <a class="dropdown-item @(isCurrent ? "active" : "")" href="@url" role="menuitem" @(isCurrent ? "aria-current=\"true\"" : "")>
                        <span class="flag-icon me-2">@lang.FlagIcon</span>
                        <span class="lang-native-name">@lang.NativeName</span>
                        <span class="lang-code ms-2 text-muted">(@lang.Code.ToUpper())</span>
                        @if (isCurrent)
                        {
                            <i class="fas fa-check ms-2 text-primary"></i>
                        }
                    </a>
                </li>
            }
        </ul>
    </div>
}